      "name": "GET Başarı Testi",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"HTTP 200 döndü\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"API responseStatus 200 döndü\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.responseStatus).to.eql(200);\r",
              "});\r",
              "\r",
              "pm.test(\"translatedText alanı dolu geldi\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.responseData.translatedText).to.be.a(\"string\");\r",
              "    pm.expect(json.responseData.translatedText).to.not.be.empty;\r",
              "    pm.expect(json.responseData.translatedText).to.not.include(\"INVALID\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response süresi 2sn altında\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
